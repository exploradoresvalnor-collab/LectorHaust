rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Chat Global
    match /global_chat/{messageId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 1. User Profiles & Stats (Publicly readable, only owner can write)
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      // Allow adding friends (updating the 'friends' array only)
      allow update: if isAuthenticated();
      
      // Sub-collections: Specific rules for each to avoid greedy conflicts
      
      // Private data (Favorites, History, Settings)
      match /favorites/{docId} { allow read, write: if isOwner(userId); }
      match /history/{docId} { allow read, write: if isOwner(userId); }
      match /readChapters/{docId} { allow read, write: if isOwner(userId); }
      match /privateChats/{docId} { allow read, write: if isOwner(userId); }

      // Friend Requests (Sender must be able to create/read/delete, Receiver must be able to read/delete)
      match /friendRequests/{senderId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == senderId);
      }
    }
    
    // 2. Comentarios (Lectura pública, Escritura autenticada, Borrado solo de autor)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() < 1000;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if false; // Por ahora no permitimos editar para evitar spam
    }
    
    // 3. Notificaciones (Solo el destinatario puede leer y marcar como leídas)
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if request.auth != null; // Cualquiera puede enviar si hay respuesta
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // 4. Reportes y Moderación (Usuario puede crear, nadie puede leer excepto Admin desde la consola)
    match /reports/{reportId} {
      allow read, update, delete: if false;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['messageId', 'reportedUserId', 'reporterId', 'reason', 'timestamp']);
    }
    
    // 4. Estadísticas de Usuario (Gamificación - Lectura para todos, Escritura protegida)
    match /userStats/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
