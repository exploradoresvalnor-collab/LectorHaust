rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de ayuda para limpieza y seguridad
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // 1. Perfiles de Usuario y Datos Privados
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      // --- Sub-colecciones Específicas ---
      
      // Favoritos, Historial, Ajustes (Solo el dueño)
      match /favorites/{docId} { allow read, write: if isOwner(userId); }
      match /history/{docId} { allow read, write: if isOwner(userId); }
      match /readChapters/{docId} { allow read, write: if isOwner(userId); }
      
      // Estado de Chat Privado (Contadores de pendientes)
      match /privateChats/{friendId} { 
        allow read, write: if isOwner(userId);
        // El emisor del mensaje puede incrementar el unreadCount del receptor
        allow create, update: if isAuthenticated() && request.auth.uid == friendId;
      }

      // Solicitudes de Amistad
      match /friendRequests/{senderId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == senderId);
      }
    }
    
    // 2. Chats (Global)
    match /global_chat/{messageId} {
      allow read: if true;
      // Solo puede crear mensajes si está logueado y no está falsificando su UID
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() < 1000;
      
      // Solo puede borrar sus mensajes
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false; // No se permite editar mensajes globales por ahora
    }
    
    // 3. Comentarios (Lectura pública, Escritura protegida)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() < 1000;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if false; 
    }
    
    // 4. Notificaciones
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated(); 
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    // 5. Reportes (Cualquiera puede crear, nadie puede leer)
    match /reports/{reportId} {
      allow read, update, delete: if false;
      allow create: if isAuthenticated();
    }
    
    // 6. Estadísticas de Usuario (Gamificación)
    match /userStats/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // 7. Chats Privados (Colección superior para mensajes directos)
    match /private_chats/{chatId}/{anyDocument=**} {
      // Usamos .matches() para mayor seguridad al buscar el UID dentro del ID del chat (uid1_uid2)
      allow read: if isAuthenticated() && chatId.matches('.*' + request.auth.uid + '.*');
                  
      // Solo puede enviar mensajes si es parte del chat Y no falsifica su identidad
      allow create: if isAuthenticated() 
                    && chatId.matches('.*' + request.auth.uid + '.*')
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() < 1000;
                    
      // Solo puede borrar sus propios mensajes
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false; // No se permite editar privados
    }
  }
}
